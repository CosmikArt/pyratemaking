<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<title>{{ title }}</title>
<style>
  body { font-family: 'Helvetica Neue', Arial, sans-serif; max-width: 960px; margin: 2rem auto; color: #222; }
  h1 { border-bottom: 2px solid #444; padding-bottom: .2rem; }
  h2 { margin-top: 2.4rem; color: #444; }
  .meta { color: #666; font-size: .9rem; }
  table { border-collapse: collapse; margin: .8rem 0 1.6rem; font-size: .92rem; }
  th, td { padding: .35rem .65rem; border-bottom: 1px solid #ddd; text-align: right; }
  th { background: #f6f6f6; text-align: left; }
  td:first-child, th:first-child { text-align: left; }
  caption { caption-side: top; font-weight: 600; padding: .2rem 0; text-align: left; }
  .indication-summary { font-size: 1.05rem; padding: .8rem 1rem; background: #f9f9f9; border-left: 4px solid #336699; }
</style>
</head>
<body>

<h1>{{ title }}</h1>
<p class="meta">Prepared {{ prepared_on }} — Werner &amp; Modlin (CAS, 5th ed.) workflow.</p>

{% if indication %}
<h2>1. Overall rate level indication</h2>
<div class="indication-summary">
  Indicated rate change: <strong>{{ indication.rate_change }}</strong>
  ({{ indication.method }}, credibility {{ indication.credibility }}).
</div>
{{ indication.table | safe }}
{% endif %}

{% if onleveling %}
<h2>2. On-leveling exhibit</h2>
{{ onleveling.table | safe }}
{% endif %}

{% if trending %}
<h2>3. Trend selection</h2>
{{ trending.table | safe }}
{% endif %}

{% if development %}
<h2>4. Loss development</h2>
{{ development.table | safe }}
{% endif %}

{% if classification %}
<h2>5. Classification relativities</h2>
{% for var, rel_table in classification.relativities.items() %}
  <h3>{{ var }}</h3>
  {{ rel_table | safe }}
{% endfor %}
{% endif %}

{% if implementation %}
<h2>6. Implementation impact</h2>
{{ implementation.dispersion | safe }}
{% if implementation.segment %}
  <h3>By segment</h3>
  {{ implementation.segment | safe }}
{% endif %}
{% endif %}

<hr>
<p class="meta">Generated by pyratemaking v{{ version }}.</p>
</body>
</html>
